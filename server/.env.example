# Backend Port
PORT=5000

# Database Connection (Supabase/Neon/Railway PostgreSQL)
# Example: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Secret for JWT signing
JWT_SECRET="generate_a_long_random_and_secure_string_here"

# Frontend URL for CORS (no trailing slash)
# Example: https://safevoice.vercel.app
FRONTEND_URL="http://localhost:5173"
